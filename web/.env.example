# Copy to `.env.local` in this folder (`web/`) — used only when running `npm run web:dev`.
# Production (`npm run web:build` / Netlify) never enables this path (DEV is false in the bundle).

# Option A — debug parsing/UI only (no Identity on localhost).
# Comment this out if you need Option B.
VITE_DEV_SKIP_IDENTITY=1

# Option B — test real login from localhost (no "Development Settings" modal if set).
# Comment out Option A above, then uncomment and set your site (Identity must be enabled on Netlify):
# VITE_NETLIFY_IDENTITY_URL=https://YOUR-SITE.netlify.app/.netlify/identity
#
# After changing `.env.local`, restart `npm run web:dev` so Vite reloads env vars.
# URL must end with `/.netlify/identity` (not `.../functions/identity`).
