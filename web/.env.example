# Copy to `.env.local` in this folder (`web/`).
# Used only by raw Vite dev (`npm run web:dev`).
#
# Raw Vite is for UI/parser work only. It does not provide the same-origin
# `/.netlify/identity` endpoint required for real Netlify Identity login.
# Use `netlify dev` for local auth + Functions + Database verification.

VITE_DEV_SKIP_IDENTITY=1
